PROJECT_NAME="VocalMind API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# Generate a strong key: `openssl rand -hex 32`
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"
GOOGLE_API_KEY=""
# Manager Assistant: Gemini model fallbacks (comma-separated)
ASSISTANT_GEMINI_MODEL="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"
# LLM provider: auto (Gemini if GOOGLE_API_KEY set, else Ollama), gemini, or ollama
ASSISTANT_LLM_PROVIDER="auto"
# Local Ollama model for text-to-SQL when using ollama or as fallback (pull e.g. llama3.2)
ASSISTANT_OLLAMA_MODEL="qwen2.5:7b"

# Database (Docker Postgres)
# Host-side port is 5434 (mapped from container's 5432) to avoid conflicts with
# a native PostgreSQL service that may already be bound to 5432 on Windows.
#
# For Supabase, use the Connection Pooling URI from the project dashboard:
#   postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# and set SEED_DEMO_DATA=false (see below) so the demo seeders don't run.
DATABASE_URL="postgresql+asyncpg://vocalmind:vocalmind_dev@localhost:5434/vocalmind"
ASSISTANT_DATABASE_URL="postgresql+asyncpg://vocalmind_readonly:vocalmind_readonly_dev@localhost:5434/vocalmind"

# Demo seeders. Leave True for local dev (creates the Nexalink + Meridian demo
# orgs and their users on every boot). Set False for any deployment pointed at
# a shared/production DB — otherwise startup will keep re-creating demo data.
SEED_DEMO_DATA=true

# AI Service Routing
# true = local Docker services
# false = Kaggle inference server
IS_LOCAL=false
EMOTION_API_URL="http://localhost:8001"
VAD_API_URL="http://localhost:8002"
WHISPERX_API_URL="http://localhost:8003"

# MLflow Tracking & DagsHub Integration
MLFLOW_TRACKING_URI="https://dagshub.com/jalalqassas/vocalMind.mlflow"
MLFLOW_TRACKING_USERNAME="jalalqassas"
MLFLOW_TRACKING_PASSWORD="" # Set to your DagsHub Personal Access Token



KAGGLE_SERVER_URL="https://etta-cleistogamous-untangentially.ngrok-free.dev"

# System
FFMPEG_PATH=""
# Backward-compatible fallback only
KAGGLE_NGROK_URL="https://xxxx.ngrok-free.app"
HF_TOKEN="your_huggingface_token"

# Text Emotion Fusion
TEXT_EMOTION_PROVIDER="hf_transformers"
TEXT_EMOTION_MODEL="j-hartmann/emotion-english-distilroberta-base"

# Min segment duration (seconds) for emotion sampling. Segments shorter than
# this inherit the previous segment's emotion instead of getting an
# independent (often low-confidence) prediction. Set to 0 to disable.
EMOTION_MIN_SEGMENT_SECS="1.0"

# LLM trigger (Groq + LangChain) — required when LLM_PROVIDER=groq (default)
# GROQ_API_KEY=          # Optional — only needed when LLM_PROVIDER=groq
LLM_MODEL="llama-3.3-70b-versatile"
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── Ollama Cloud (replaces Groq + local Ollama when LLM_PROVIDER=ollama_cloud) ──
OLLAMA_API_KEY=                              # https://ollama.com/settings → API Keys
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_HEAVY_MODEL=kimi-k2.6:cloud      # default heavy model (benchmark-validated)
OLLAMA_CLOUD_FAST_MODEL=ministral-3:8b         # from benchmark report
# New per-stage routing vars (fallback to class default when unset):
# heavy: emotion_shift, process_adherence, text_to_sql -> OLLAMA_CLOUD_HEAVY_MODEL
# fast: nli_policy, rag_judge, fast_classification -> OLLAMA_CLOUD_FAST_MODEL
# rag_synthesis intentionally preserves legacy fallback to settings.groq.model when unset
OLLAMA_MODEL_EMOTION_SHIFT=
OLLAMA_MODEL_PROCESS_ADHERENCE=
OLLAMA_MODEL_NLI_POLICY=
OLLAMA_MODEL_RAG_JUDGE=
OLLAMA_MODEL_TEXT_TO_SQL=
OLLAMA_MODEL_FAST_CLASSIFICATION=
OLLAMA_MODEL_RAG_SYNTHESIS=
# Per-stage heavy models (fallback to OLLAMA_CLOUD_HEAVY_MODEL when unset)
OLLAMA_EMOTION_SHIFT_MODEL=kimi-k2.5:cloud           # v7 GT winner (v2 prompt, 53% exact)
OLLAMA_PROCESS_ADHERENCE_MODEL=kimi-k2.6:cloud       # v7 GT F1 winner (0.546 errors_as_0; not qwen3.5 excl-errors)
OLLAMA_NLI_MODEL=ministral-3:8b                      # v7 GT exact winner (52%)
# NOTE: fast_classification has no production runtime call site yet; variable is
# defined for config parity with benchmark stages and future wiring.
OLLAMA_CLOUD_EMBED_ENABLED=false               # set true after embedding benchmark

# ── Provider switch ──
LLM_PROVIDER=ollama_cloud                      # groq | ollama_cloud
ASSISTANT_LLM_PROVIDER=auto                    # gemini | groq | ollama_cloud | ollama | auto

# RAG / embeddings (local Ollama or Ollama Cloud when OLLAMA_CLOUD_EMBED_ENABLED=true)
# Docker Compose overrides this to http://ollama:11434 for backend + ingestion containers.
# Use localhost only when running backend/ingestion directly on the host (not in compose).
OLLAMA_BASE_URL="http://localhost:11434"
EMBEDDING_MODEL="snowflake-arctic-embed2"
EMBEDDING_DIMENSION=1024
QDRANT_URL="http://localhost:6333"

# Missing variables matching Settings in config.py
FRONTEND_URL="http://localhost:3000"
ASSISTANT_OLLAMA_TIMEOUT_SECONDS=120.0
LOCAL_AUDIO_STORAGE_DIR="storage/uploads"
# local = VM/container disk, supabase = upload new audio to Supabase Storage
AUDIO_STORAGE_BACKEND="local"

# Supabase
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_AUDIO_BUCKET="recordings"
# Direct Postgres URI for schema migrations (Dashboard → Database → Connection string)
# Use the **Connection pooling** URI (IPv4) if direct db.* host fails from Docker.
# Password special chars must be URL-encoded (@ → %40).
SUPABASE_DB_URL=""

# LLM Triggers
GROQ_API_KEY=""
LLM_REQUEST_TIMEOUT_SECONDS=60.0

# RAG & Vector DB
QDRANT_COLLECTION_PARENTS="vocalmind_parents"
QDRANT_COLLECTION_SOP_PARENTS="vocalmind_sop_parents"
EMBEDDING_TIMEOUT_SECONDS=60.0
SOP_RETRIEVAL_TOP_K=4
SOP_MAX_CHUNKS=2
RAG_SUPPORTED_THRESHOLD=0.82
RAG_NEUTRAL_THRESHOLD=0.55

# Knowledge Docs Paths (resolves relative to app root or absolute)
POLICY_DOCS_ROOT="storage/docs"
SOP_DOCS_ROOT="storage/docs"
KNOWLEDGE_DOCS_ROOT="storage/docs"
POLICY_PARSED_DOCS_ROOT="storage/docs"
SOP_PARSED_DOCS_ROOT="storage/docs"

# Assistant
OPENAI_API_KEY=""
SEED_EVALUATION_SESSIONS=false
AUDIO_FOLDER_WATCHER_ENABLED=true
