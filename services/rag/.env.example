# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Ollama (default: localhost if running via Docker Compose)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (pulled via: ollama pull snowflake-arctic-embed2)
EMBEDDING_MODEL=snowflake-arctic-embed2

# Qdrant (default: localhost if running via Docker Compose)
QDRANT_URL=http://localhost:6333

# Document paths for this repo layout.
# When running locally from services/rag, these resolve to the repo root storage/docs folder.
DOCS_DIR=../../storage/docs
PARSED_DIR=../../storage/docs

# Provider switch
LLM_PROVIDER=groq

# Ollama Cloud defaults
OLLAMA_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_HEAVY_MODEL=kimi-k2.6:cloud
OLLAMA_CLOUD_FAST_MODEL=ministral-3:8b

# New per-stage routing vars (fallback to class default when unset):
# heavy: emotion_shift, process_adherence, text_to_sql -> OLLAMA_CLOUD_HEAVY_MODEL
# fast: nli_policy, rag_judge, fast_classification -> OLLAMA_CLOUD_FAST_MODEL
# rag_synthesis intentionally preserves legacy fallback to settings.groq.model when unset
OLLAMA_MODEL_EMOTION_SHIFT=
OLLAMA_MODEL_PROCESS_ADHERENCE=
OLLAMA_MODEL_NLI_POLICY=
OLLAMA_MODEL_RAG_JUDGE=
OLLAMA_MODEL_TEXT_TO_SQL=
OLLAMA_MODEL_FAST_CLASSIFICATION=
OLLAMA_MODEL_RAG_SYNTHESIS=

# Legacy per-stage vars remain supported as fallbacks for existing setups:
OLLAMA_EMOTION_SHIFT_MODEL=
OLLAMA_PROCESS_ADHERENCE_MODEL=
OLLAMA_NLI_MODEL=

# NOTE: fast_classification has no production runtime call site yet; variable is
# defined for config parity with benchmark stages and future wiring.

# ── Cross-encoder reranking ──
# Retrieval pulls RERANK_CANDIDATE_K chunks from Qdrant, reranks them with a
# cross-encoder, then keeps similarity_top_k. Boosts context precision.
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATE_K=20

# ── RAGAS judge LLM ──
# Provider: local | groq | vertex.
#   vertex — Vertex AI Gemini via service account. BEST: reliable, grades all
#            samples, billed to GCP credits (no free-tier req/day cap). The
#            AI Studio API key path is free-tier (gemini-2.5-flash = 20 req/day)
#            and CANNOT run RAGAS (needs ~150 calls/run).
#   groq   — Groq llama-3.3-70b (100k token/day cap ≈ 1 run/day; rejects n>1).
#   local  — LM Studio (offline; weakest, caps ~0.74, emits NaN/zeros).
RAGAS_JUDGE_PROVIDER=local

# local-judge settings (use a plain INSTRUCT model, not a vision "-vl" variant):
RAGAS_JUDGE_MODEL=qwen2.5-7b-instruct
RAGAS_JUDGE_BASE_URL=http://localhost:1234/v1
RAGAS_JUDGE_API_KEY=lm-studio

# vertex-judge settings (RAGAS_JUDGE_PROVIDER=vertex):
#   RAGAS_JUDGE_MODEL=google/gemini-2.5-flash
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_SA_FILE=

# ── Synthesis prompt mode ──
# safe (default) — grounded + admits uncertainty (production-safe for compliance).
# assertive      — never hedges; maximizes RAGAS answer-relevancy for evaluation.
SYNTHESIS_PROMPT_MODE=safe

# ── Local synthesis override (skip Groq; e.g. LM Studio) ──
# Leave SYNTHESIS_BASE_URL empty to use the production Groq model for synthesis.
SYNTHESIS_BASE_URL=
SYNTHESIS_MODEL=
SYNTHESIS_API_KEY=lm-studio

# Privacy-sensitive query logging:
# false (default) = do not persist question/chunk/response content to disk
# true            = write logs/query_*.json with full query context for debugging
RAG_QUERY_LOG_ENABLED=false

