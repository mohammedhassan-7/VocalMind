# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Ollama (default: localhost if running via Docker Compose)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (pulled via: ollama pull snowflake-arctic-embed2)
EMBEDDING_MODEL=snowflake-arctic-embed2

# Qdrant (default: localhost if running via Docker Compose)
QDRANT_URL=http://localhost:6333

# Document paths for this repo layout.
# When running locally from services/rag, these resolve to the repo root storage/docs folder.
DOCS_DIR=../../storage/docs
PARSED_DIR=../../storage/docs

