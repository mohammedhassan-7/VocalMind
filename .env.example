MLFLOW_TRACKING_URI="https://dagshub.com/jalalqassas/vocalMind.mlflow"
MLFLOW_TRACKING_USERNAME="jalalqassas"
MLFLOW_TRACKING_PASSWORD="" # Set to your DagsHub Personal Access Token

# ────────────────────────────────────────────────────────────────────────────
# Missing VocalMind Settings matching config.py
# ────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=""
ASSISTANT_GEMINI_MODEL="gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash"
ASSISTANT_LLM_PROVIDER="auto"
ASSISTANT_OLLAMA_MODEL="qwen2.5:7b"
ASSISTANT_OLLAMA_TIMEOUT_SECONDS=120.0

SPEAKER_ROLE_MODEL_DIR=""
BACKEND_SPEAKER_RELABEL_ENABLED=false

SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

LLM_REQUEST_TIMEOUT_SECONDS=60.0
EMBEDDING_TIMEOUT_SECONDS=60.0
SOP_MAX_CHUNKS=2
RAG_SUPPORTED_THRESHOLD=0.82
RAG_NEUTRAL_THRESHOLD=0.55

POLICY_DOCS_ROOT="storage/docs"
SOP_DOCS_ROOT="storage/docs"
KNOWLEDGE_DOCS_ROOT="storage/docs"
