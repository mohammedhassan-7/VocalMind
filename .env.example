# ============================================================================
# VocalMind - Comprehensive Environment Configuration
# Copy to .env and fill in your actual values
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# Database (Docker Postgres)
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://vocalmind:vocalmind_dev@db:5432/vocalmind"

# ────────────────────────────────────────────────────────────────────────────
# Backend Security
# ────────────────────────────────────────────────────────────────────────────
SECRET_KEY="your-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────────────────────
# AI Service Routing
# true = Docker containers (IS_LOCAL=true)
# false = Kaggle inference server
# ────────────────────────────────────────────────────────────────────────────
IS_LOCAL=true
EMOTION_API_URL="http://emotion:8000"
VAD_API_URL="http://vad:8002"
WHISPERX_API_URL="http://whisperx:8000"

# ────────────────────────────────────────────────────────────────────────────
# Kaggle Server (only used if IS_LOCAL=false)
# ────────────────────────────────────────────────────────────────────────────
KAGGLE_SERVER_URL=""
KAGGLE_NGROK_URL=""

# ────────────────────────────────────────────────────────────────────────────
# Google OAuth (optional)
# ────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# ────────────────────────────────────────────────────────────────────────────
# LLM & Reasoning
# ────────────────────────────────────────────────────────────────────────────
# Groq API key (get from https://console.groq.com)
GROQ_API_KEY="gsk_your_groq_api_key_here"
LLM_MODEL="llama-3.3-70b-versatile"
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ────────────────────────────────────────────────────────────────────────────
# RAG & Vector DB
# ────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://ollama:11434"
EMBEDDING_MODEL="snowflake-arctic-embed2"
QDRANT_URL="http://qdrant:6333"
QDRANT_COLLECTION_PARENTS="vocalmind_parents"
QDRANT_COLLECTION_SOP_PARENTS="vocalmind_sop_parents"
SOP_RETRIEVAL_TOP_K=3

# ────────────────────────────────────────────────────────────────────────────
# Text Emotion Fusion
# ────────────────────────────────────────────────────────────────────────────
TEXT_EMOTION_PROVIDER="hf_transformers"
TEXT_EMOTION_MODEL="j-hartmann/emotion-english-distilroberta-base"
TEXT_EMOTION_BATCH_SIZE=32

# ────────────────────────────────────────────────────────────────────────────
# External APIs & Models
# ────────────────────────────────────────────────────────────────────────────
HF_TOKEN="hf_your_huggingface_token_here"
ELEVENLABS_API_KEY=""
LLAMA_CLOUD_API_KEY=""
PINECONE_API_KEY=""
PINECONE_INDEX_NAME=""

# ────────────────────────────────────────────────────────────────────────────
# System Configuration
# ────────────────────────────────────────────────────────────────────────────
FFMPEG_PATH=""
LOCAL_AUDIO_STORAGE_DIR="storage/uploads"